{
  "permissions": {
    "allow": [
      "Bash(centy:*)",
      "Bash(centy create:*)",
      "Bash(git push:*)",
      "Bash(uuidgen:*)",
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "Bash(npm info:*)",
      "Bash(npm search:*)",
      "Bash(command:*)",
      "Bash(git status:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm dlx block-no-verify"
          }
        ]
      }
    ]
  }
}
