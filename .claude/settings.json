{
  "permissions": {
    "allow": [
      "Bash(centy:*)",
      "Bash(centy create:*)",
      "Bash(git push:*)",
      "Bash(uuidgen:*)",
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "Bash(npm info:*)",
      "Bash(npm search:*)",
      "Bash(command:*)",
      "Bash(git status:*)",
      "Bash(pnpm dlx:*)",
      "Bash(cargo outdated:*)",
      "Bash(cargo search:*)",
      "Bash(npx centy:*)",
      "Bash(cargo check:*)",
      "Bash(cargo run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Bash(cargo info:*)",
      "WebFetch(domain:docs.rs)",
      "Bash(cargo fmt:*)",
      "Bash(grep:*)",
      "Bash(cargo build:*)",
      "Bash(git config:*)",
      "Bash(gh issue:*)",
      "Bash(command:*)"
    ],
    "deny": ["Bash(gh issue create:*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm dlx block-no-verify"
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm dlx ai-fs-permissions --op read"
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm dlx ai-fs-permissions --op write"
          }
        ]
      }
    ]
  }
}
